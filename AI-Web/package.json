{
  "name": "ai-web",
  "version": "1.0.0",
  "private": true,
  "description": "A pnpm monorepo with ai project",
  "scripts": {
    "dev:admin": "pnpm --filter admin dev",
    "dev:web": "pnpm --filter web dev",
    "dev:bff": "pnpm --filter bff start:dev",
    "build:all": "pnpm -r --filter \"./apps/*\" build",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  }
}